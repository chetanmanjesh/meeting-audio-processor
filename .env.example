DEEPGRAM_API_KEY=your_deepgram_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
SARVAM_API_KEY=your_sarvam_subscription_key_here

# LLM provider switch — "claude" (default), "gemini", or "deepseek".
#   claude:   Anthropic Sonnet. Most polished, ~₹25/meeting.
#   gemini:   Free up to ~1,500 req/day from https://aistudio.google.com/app/apikey
#             but capacity-bursty (occasional 503 overloads on free tier).
#   deepseek: Paid but ~10× cheaper than Claude (~₹2/meeting). Get key at
#             https://platform.deepseek.com/api_keys
LLM_PROVIDER=claude
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
